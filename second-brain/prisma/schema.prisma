generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  name        String
  sub         String   @unique
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  picture_url String
  workspace   Workspace[]
}

model Workspace {
  id         Int      @id @default(autoincrement())
  name       String
  owner_id   Int
  owner      User     @relation(fields: [owner_id], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  pages      Page[]

  @@index([owner_id])
}

model Page {
  id             Int      @id @default(autoincrement())
  title          String
  content        Json?
  icon           String
  color          String
  workspace_id   Int
  workspace      Workspace @relation(fields: [workspace_id], references: [id])
  parent_page_id Int?
  parent         Page?    @relation("PageHierarchy", fields: [parent_page_id], references: [id])
  children       Page[]   @relation("PageHierarchy")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([workspace_id])
  @@index([parent_page_id])
}